# Cloudflare Pages headers. This buildless app has STABLE filenames (no content
# hashes), so a long browser TTL means a new deploy is shadowed by the cached old
# modules until the TTL expires. The JS was defaulting to max-age=14400 (4h), so
# returning visitors kept stale code for hours after a deploy — and because the
# experience is embedded in a cross-origin <iframe>, even a parent hard-refresh
# doesn't bust the iframe's cached subresources.
#
# Force the HTML + JS modules to always revalidate. With ETags this is a tiny 304
# when nothing changed, and an immediate 200 with the new file right after a deploy.
# (index.html already shipped as max-age=0, must-revalidate; this extends that to
# every .html and the whole js/ module graph.)

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Large, rarely-changing assets can stay cached for a day. They have no hashed
# names either, so keep this short enough that an occasional swap propagates the
# same day; bump/purge in the Cloudflare dashboard if you need it sooner.
/*.webp
  Cache-Control: public, max-age=86400
/three.min.js
  Cache-Control: public, max-age=86400
